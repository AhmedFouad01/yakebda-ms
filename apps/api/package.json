{
  "name": "@ykms/api",
  "version": "0.1.0",
  "private": true,
  "description": "YAKEBDA MS - Backend API (YKMS-01 + YKMS-01H)",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
