{
  "name": "yakebda-ms",
  "version": "0.1.0",
  "private": true,
  "description": "YAKEBDA MS — نظام إدارة مطاعم عربي أولًا RTL (مشروع مستقل)",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "api:dev": "npm --workspace @ykms/api run dev",
    "api:migrate": "npm --workspace @ykms/api run migrate",
    "api:seed": "npm --workspace @ykms/api run seed",
    "api:e2e:reset": "npm --workspace @ykms/api run e2e:reset",
    "api:test": "npm --workspace @ykms/api run test",
    "admin:dev": "npm --workspace @ykms/admin run dev",
    "admin:build": "npm --workspace @ykms/admin run build",
    "admin:test": "npm --workspace @ykms/admin run test",
    "qa:css": "node tools/qa/audit-css.mjs",
    "qa:e2e": "playwright test --project=chromium",
    "qa:e2e:update": "playwright test --project=chromium --update-snapshots",
    "qa:final": "npm run api:test && npm run admin:test && npm run qa:css && npm run admin:build && npm run qa:e2e",
    "check": "npm run api:test && npm run admin:test && npm run qa:css && npm run admin:build",
    "audit:deps": "npm audit",
    "audit:deps:prod": "npm audit --omit=dev"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@playwright/test": "1.55.0"
  }
}
